{
  "mcpServers": {
    "circle": {
      "type": "http",
      "url": "https://api.circle.com/v1/codegen/mcp"
    },
    "lifi": {
      "type": "http",
      "url": "https://mcp.li.quest/mcp"
    },
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ]
    },
    "polymarket": {
      "command": "npx",
      "args": [
        "-y",
        "@iqai/mcp-polymarket"
      ],
      "env": {
        "POLYGON_RPC_URL": "${POLYGON_RPC:-https://polygon-rpc.com}"
      }
    },
    "foundry": {
      "command": "npx",
      "args": [
        "-y",
        "@pranesh.asp/foundry-mcp-server"
      ]
    },
    "blockscout": {
      "type": "http",
      "url": "https://mcp.blockscout.com/mcp"
    },
    "deepwiki": {
      "type": "http",
      "url": "https://mcp.deepwiki.com/mcp"
    },
    "tenderly": {
      "type": "http",
      "url": "https://mcp.tenderly.co/mcp"
    },
    "prediction": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "prediction-mcp"
      ],
      "env": {}
    }
  }
}